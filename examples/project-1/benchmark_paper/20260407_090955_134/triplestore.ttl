@prefix :        <https://example.org/ns/riepr#> .
@prefix adms:    <http://www.w3.org/ns/adms#> .
@prefix concept: <https://example.org/id/concept/> .
@prefix dbo:     <http://dbpedia.org/ontology/> .
@prefix dc:      <http://purl.org/dc/terms/> .
@prefix ex:      <https://example.org/id/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix locn:    <http://www.w3.org/ns/locn#> .
@prefix ogc:     <http://www.opengis.net/ont/geosparql#> .
@prefix org:     <http://www.w3.org/ns/org#> .
@prefix pplan:   <http://purl.org/net/p-plan#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix ssn:     <http://www.w3.org/ns/ssn/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/id/filter/dustFilter1>
        a                ssn:System , :Filter ;
        rdfs:label       "Furnace Dust Filter"@en ;
        dc:created       "2024-11-01T09:00:00"^^xsd:dateTime ;
        dc:issued        "2024-11-01"^^xsd:date ;
        dc:modified      "2026-01-15T10:00:00"^^xsd:dateTime ;
        dc:type          "ElectrostaticPrecipitator" ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/address/myGlassFactory>
        a                 locn:Address ;
        locn:fullAddress  "Industrial Zone, Belgium"@en .

<https://example.org/id/measurementinstrument/flowMeter>
        a                ssn:System , :MeasurementInstrument ;
        rdfs:label       "Effluent Flow Meter"@en ;
        dc:created       "2024-07-02T11:00:00"^^xsd:dateTime ;
        dc:issued        "2023-08-01"^^xsd:date ;
        dc:modified      "2024-07-02T11:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/operator/myGlassFactory>
        a             :Operator ;
        rdfs:label    "MyGlassFactory NV"@en ;
        dc:type       concept:organization ;
        locn:address  <https://example.org/id/address/myGlassFactory> .

<https://example.org/id/filter/waterFilter1>
        a                ssn:System , :Filter ;
        rdfs:label       "Water Intake Filter 1"@en ;
        dc:created       "2025-05-10T06:00:00"^^xsd:dateTime ;
        dc:issued        "2025-05-01"^^xsd:date ;
        dc:modified      "2026-03-20T12:00:00"^^xsd:dateTime ;
        dc:type          "BagFilter" ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/process/forming>
        a                   :Process ;
        rdfs:label          "Glass Forming"@en ;
        dc:created          "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued           "2026-04-07"^^xsd:date ;
        dc:modified         "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        pplan:isStepOfPlan  <https://example.org/id/process/glassProduction> ;
        adms:status         concept:active .

<https://example.org/id/installation/furnace>
        a                :Installation ;
        rdfs:label       "Glass Furnace"@en ;
        dc:created       "2024-01-01T08:00:00"^^xsd:dateTime ;
        dc:issued        "2020-01-01"^^xsd:date ;
        dc:modified      "2024-01-01T08:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/installation/glass-former>
        a                :Installation ;
        rdfs:label       "Glass Forming Machine"@en ;
        dc:created       "2024-06-15T09:30:00"^^xsd:dateTime ;
        dc:issued        "2021-06-15"^^xsd:date ;
        dc:modified      "2024-06-15T09:30:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/measurementpoint/stack1>
        a                 :MeasurementPoint ;
        rdfs:label        "Measurement Point Stack 1"@en ;
        dc:created        "2026-04-07T07:00:00"^^xsd:dateTime ;
        dc:issued         "2026-04-07"^^xsd:date ;
        dc:modified       "2026-04-07T07:00:00"^^xsd:dateTime ;
        adms:status       concept:active ;
        sosa:isHostedBy   <https://example.org/id/location/myGlassFactory> ;
        ssn:hasSubSystem  <https://example.org/id/measurementinstrument/gasAnalyzer> .

<https://example.org/id/withdrawalpoint/sandExtraction1>
        a                :WithdrawalPoint ;
        rdfs:label       "Sand Extraction Point A"@en ;
        dbo:depth        2.5 ;
        dc:created       "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued        "2026-04-07"^^xsd:date ;
        dc:modified      "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/process/melting>
        a                   :Process ;
        rdfs:label          "Glass Melting"@en ;
        dc:created          "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued           "2026-04-07"^^xsd:date ;
        dc:modified         "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        pplan:isStepOfPlan  <https://example.org/id/process/glassProduction> ;
        adms:status         concept:active .

<https://example.org/id/emissionpoint/stack1>
        a                :EmissionPoint ;
        rdfs:label       "Chimney Stack 1"@en ;
        dbo:diameter     1.2 ;
        dbo:height       25.0 ;
        dc:created       "2026-04-07T00:00:00"^^xsd:dateTime ;
        dc:issued        "2026-01-01"^^xsd:date ;
        dc:modified      "2026-04-07T00:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/geometry/myGlassFactory>
        a          ogc:Geometry ;
        ogc:asWKT  "POINT(4.35 50.85)"^^ogc:wktLiteral .

<https://example.org/id/withdrawalpoint/waterIntake1>
        a                 ssn:System , :WithdrawalPoint ;
        rdfs:label        "Water Intake Point 1"@en ;
        dbo:depth         5.0 ;
        dc:created        "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued         "2026-04-07"^^xsd:date ;
        dc:modified       "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        adms:status       concept:active ;
        sosa:isHostedBy   <https://example.org/id/location/myGlassFactory> ;
        ssn:hasSubSystem  <https://example.org/id/filter/waterFilter1> .

<https://example.org/id/emissionpoint/discharge1>
        a                :EmissionPoint ;
        rdfs:label       "Effluent Discharge Point A"@en ;
        dbo:depth        3.5 ;
        dc:created       "2025-06-15T08:30:00"^^xsd:dateTime ;
        dc:issued        "2025-06-01"^^xsd:date ;
        dc:modified      "2026-04-01T09:00:00"^^xsd:dateTime ;
        dc:type          "DischargePoint" ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/contactperson/janJansen>
        a             :Contactpersoon , :OperatorContactPerson ;
        rdfs:label    "Jan Jansen"@en ;
        dc:created    "2026-04-07T07:08:50Z"^^xsd:dateTime ;
        dc:issued     "2026-01-01"^^xsd:date ;
        dc:modified   "2026-04-07T07:08:50Z"^^xsd:dateTime ;
        org:hasRole   "Regulatory Contact" ;
        org:memberOf  <https://example.org/id/operation/myGlassFactory-v1> ;
        foaf:mbox     <mailto:jan.jansen@myglassfactory.example> ;
        foaf:name     "Jan Jansen" .

<https://example.org/id/location/myGlassFactory>
        a                     :OperationLocation ;
        rdfs:label            "MyGlassFactory Site"@en ;
        dc:created            "2024-01-01T00:00:00"^^xsd:dateTime ;
        dc:issued             "2024-01-01"^^xsd:date ;
        dc:modified           "2024-01-01T00:00:00"^^xsd:dateTime ;
        ogc:hasGeometry       <https://example.org/id/geometry/myGlassFactory> ;
        prov:wasAttributedTo  <https://example.org/id/operator/myGlassFactory> .

concept:active  a  adms:Status .

<https://example.org/id/measurementinstrument/gasAnalyzer>
        a                ssn:System , :MeasurementInstrument ;
        rdfs:label       "Stack Gas Analyzer"@en ;
        dc:created       "2024-07-01T10:00:00"^^xsd:dateTime ;
        dc:issued        "2022-05-01"^^xsd:date ;
        dc:modified      "2024-07-01T10:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/operation/myGlassFactory-v1>
        a                       :Operation ;
        rdfs:label              "MyGlassFactory Operation 2026"@en ;
        dc:created              "2026-04-07T07:08:50"^^xsd:dateTime ;
        dc:issued               "2026-04-07"^^xsd:date ;
        dc:modified             "2026-04-07T07:08:50"^^xsd:dateTime ;
        adms:status             concept:active ;
        ssn:deployedOnPlatform  <https://example.org/id/location/myGlassFactory> ;
        ssn:implements          <https://example.org/id/process/glassProduction> .

<https://example.org/id/process/glassProduction>
