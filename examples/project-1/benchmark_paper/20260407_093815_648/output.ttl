# ============================================================
# MyGlassFactory — RIEPR Linked Data Dataset
# Covers all 23 SHACL shapes for the glass factory scenario.
# ============================================================

@prefix :        <https://example.org/ns/riepr#> .
@prefix adms:    <http://www.w3.org/ns/adms#> .
@prefix concept: <https://example.org/id/concept/> .
@prefix dbo:     <http://dbpedia.org/ontology/> .
@prefix dc:      <http://purl.org/dc/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix locn:    <http://www.w3.org/ns/locn#> .
@prefix ogc:     <http://www.opengis.net/ont/geosparql#> .
@prefix org:     <http://www.w3.org/ns/org#> .
@prefix pplan:   <http://purl.org/net/p-plan#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix ssn:     <http://www.w3.org/ns/ssn/> .
@prefix unit:    <http://qudt.org/vocab/unit/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# -- Shared status concept --
concept:active  a  adms:Status .

# ============================================================
# OPERATOR AND LOCATION
# ============================================================

<https://example.org/id/operator/myGlassFactory>
        a             :Operator ;
        rdfs:label    "MyGlassFactory NV"@en ;
        dc:type       concept:organization ;
        locn:address  <https://example.org/id/address/myGlassFactory> .

<https://example.org/id/address/myGlassFactory>
        a                 locn:Address ;
        locn:fullAddress  "Industrial Zone, Belgium"@en .

<https://example.org/id/location/myGlassFactory>
        a                     :OperationLocation ;
        rdfs:label            "MyGlassFactory Site"@en ;
        dc:created            "2024-01-01T00:00:00"^^xsd:dateTime ;
        dc:issued             "2024-01-01"^^xsd:date ;
        dc:modified           "2024-01-01T00:00:00"^^xsd:dateTime ;
        ogc:hasGeometry       <https://example.org/id/geometry/myGlassFactory> ;
        prov:wasAttributedTo  <https://example.org/id/operator/myGlassFactory> .

<https://example.org/id/geometry/myGlassFactory>
        a          ogc:Geometry ;
        ogc:asWKT  "POINT(4.35 50.85)"^^ogc:wktLiteral .

# ============================================================
# OPERATION
# ============================================================

<https://example.org/id/operation/myGlassFactory-v1>
        a                       :Operation ;
        rdfs:label              "MyGlassFactory Operation 2026"@en ;
        dc:created              "2026-04-07T07:08:50"^^xsd:dateTime ;
        dc:issued               "2026-04-07"^^xsd:date ;
        dc:modified             "2026-04-07T07:08:50"^^xsd:dateTime ;
        adms:status             concept:active ;
        ssn:deployedOnPlatform  <https://example.org/id/location/myGlassFactory> ;
        ssn:implements          <https://example.org/id/process/glassProduction> .

# ============================================================
# CONTACT PERSONS
# ============================================================

<https://example.org/id/contactperson/janJansen>
        a             :OperatorContactPerson ;
        rdfs:label    "Jan Jansen"@en ;
        foaf:name     "Jan Jansen" ;
        foaf:mbox     <mailto:jan.jansen@myglassfactory.example> ;
        org:hasRole   "Regulatory Contact" ;
        org:memberOf  <https://example.org/id/operation/myGlassFactory-v1> ;
        dc:created    "2026-04-07T07:08:50Z"^^xsd:dateTime ;
        dc:issued     "2026-01-01"^^xsd:date ;
        dc:modified   "2026-04-07T07:08:50Z"^^xsd:dateTime .

<https://example.org/id/contactperson/annaDeRoeck>
        a             :OperatorContactPerson ;
        rdfs:label    "Anna De Roeck"@en ;
        foaf:name     "Anna De Roeck" ;
        foaf:mbox     <mailto:anna.deroeck@myglassfactory.example> ;
        foaf:phone    "+32-123-456-789" ;
        org:hasRole   "Environmental Officer" ;
        org:memberOf  <https://example.org/id/operation/myGlassFactory-v1> ;
        dc:created    "2026-04-07T07:08:50Z"^^xsd:dateTime ;
        dc:issued     "2026-01-01"^^xsd:date ;
        dc:modified   "2026-04-07T07:08:50Z"^^xsd:dateTime .

# ============================================================
# PROCESSES
# ============================================================

<https://example.org/id/process/glassProduction>
        a            :Process ;
        rdfs:label   "Glass Production Process"@en ;
        dc:created   "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued    "2026-04-07"^^xsd:date ;
        dc:modified  "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        adms:status  concept:active .

<https://example.org/id/process/melting>
        a                   :Process ;
        rdfs:label          "Glass Melting"@en ;
        dc:created          "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued           "2026-04-07"^^xsd:date ;
        dc:modified         "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        pplan:hasInputVar   <https://example.org/id/processvariable/sand> ,
                            <https://example.org/id/processvariable/naturalGas> ;
        pplan:hasOutputVar  <https://example.org/id/processvariable/moltenGlass> ;
        pplan:isStepOfPlan  <https://example.org/id/process/glassProduction> ;
        adms:status         concept:active ;
        :section            <https://example.org/id/section/A1> .

<https://example.org/id/process/forming>
        a                   :Process ;
        rdfs:label          "Glass Forming"@en ;
        dc:created          "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued           "2026-04-07"^^xsd:date ;
        dc:modified         "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        pplan:isStepOfPlan  <https://example.org/id/process/glassProduction> ;
        adms:status         concept:active ;
        :section            <https://example.org/id/section/C1> .

# ============================================================
# PROCESS VARIABLES
# ============================================================

<https://example.org/id/processvariable/sand>
        a           pplan:Variable , :ProcessVariable ;
        rdfs:label  "Sand (Input)"@en ;
        dc:type     concept:rawMaterial .

<https://example.org/id/processvariable/naturalGas>
        a                  pplan:Variable , :ProcessVariable ;
        rdfs:label         "Natural Gas (Fuel Input)"@en ;
        dc:type            concept:fuel ;
        qudt:numericValue  "1500.0"^^xsd:decimal ;
        qudt:hasUnit       unit:M3 .

<https://example.org/id/processvariable/moltenGlass>
        a           pplan:Variable , :ProcessVariable ;
        rdfs:label  "Molten Glass (Output)"@en ;
        dc:type     concept:product .

# ============================================================
# SECTIONS
# ============================================================

<https://example.org/id/section/A1>
        a                :Section ;
        dc:type          concept:combustionSection ;
        skos:notation    "A1" ;
        skos:definition  "Combustion and melting processes"@en .

<https://example.org/id/section/B1>
        a                :Section ;
        dc:type          concept:emissionSection ;
        skos:notation    "B1" ;
        skos:definition  "Air emission monitoring"@en .

<https://example.org/id/section/C1>
        a                :Section ;
        dc:type          concept:processSection ;
        skos:notation    "C1" ;
        skos:definition  "Forming and finishing processes"@en .

# ============================================================
# INSTALLATIONS AND PROPERTIES
# ============================================================

<https://example.org/id/installation/furnace>
        a                :Installation ;
        rdfs:label       "Glass Furnace"@en ;
        dc:created       "2024-01-01T08:00:00"^^xsd:dateTime ;
        dc:issued        "2020-01-01"^^xsd:date ;
        dc:modified      "2024-01-01T08:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> ;
        ssn:hasProperty  <https://example.org/id/installationproperty/furnace-capacity> ,
                         <https://example.org/id/installationproperty/furnace-temperature> .

<https://example.org/id/installation/glass-former>
        a                :Installation ;
        rdfs:label       "Glass Forming Machine"@en ;
        dc:created       "2024-06-15T09:30:00"^^xsd:dateTime ;
        dc:issued        "2021-06-15"^^xsd:date ;
        dc:modified      "2024-06-15T09:30:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> ;
        ssn:hasProperty  <https://example.org/id/installationproperty/glassformer-power> .

<https://example.org/id/installationproperty/furnace-capacity>
        a                  :InstallationProperty ;
        dc:type            concept:nominalCapacity ;
        qudt:numericValue  "200.0"^^xsd:decimal ;
        qudt:hasUnit       unit:TON-PER-DAY ;
        ssn:isPropertyOf   <https://example.org/id/installation/furnace> .

<https://example.org/id/installationproperty/furnace-temperature>
        a                  :InstallationProperty ;
        dc:type            concept:maxOperatingTemperature ;
        qudt:numericValue  "1600.0"^^xsd:decimal ;
        qudt:hasUnit       unit:DEG_C ;
        ssn:isPropertyOf   <https://example.org/id/installation/furnace> .

<https://example.org/id/installationproperty/glassformer-power>
        a                  :InstallationProperty ;
        dc:type            concept:installedPower ;
        qudt:numericValue  "2.5"^^xsd:decimal ;
        qudt:hasUnit       unit:MegaW ;
        ssn:isPropertyOf   <https://example.org/id/installation/glass-former> .

# ============================================================
# EMISSION POINTS
# ============================================================

<https://example.org/id/emissionpoint/stack1>
        a                :EmissionPoint ;
        rdfs:label       "Chimney Stack 1"@en ;
        dbo:diameter     "1.2"^^xsd:decimal ;
        dbo:height       "25.0"^^xsd:decimal ;
        dc:created       "2026-04-07T00:00:00"^^xsd:dateTime ;
        dc:issued        "2026-01-01"^^xsd:date ;
        dc:modified      "2026-04-07T00:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/emissionpoint/discharge1>
        a                :EmissionPoint ;
        rdfs:label       "Effluent Discharge Point A"@en ;
        dbo:depth        "3.5"^^xsd:decimal ;
        dc:created       "2025-06-15T08:30:00"^^xsd:dateTime ;
        dc:issued        "2025-06-01"^^xsd:date ;
        dc:modified      "2026-04-01T09:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

# ============================================================
# ABSTRACT EMISSION POINTS
# ============================================================

<https://example.org/id/abstractemissionpoint/stack-group>
        a           :AbstractEmissionPoint ;
        rdfs:label  "Stack Emission Group"@en ;
        dc:type     concept:airEmission .

<https://example.org/id/abstractemissionpoint/water-group>
        a           :AbstractEmissionPoint ;
        rdfs:label  "Water Discharge Group"@en ;
        dc:type     concept:waterEmission .

# ============================================================
# WITHDRAWAL POINTS
# ============================================================

<https://example.org/id/withdrawalpoint/waterIntake1>
        a                 ssn:System , :WithdrawalPoint ;
        rdfs:label        "Water Intake Point 1"@en ;
        dbo:depth         "5.0"^^xsd:decimal ;
        dc:created        "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued         "2026-04-07"^^xsd:date ;
        dc:modified       "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        adms:status       concept:active ;
        sosa:isHostedBy   <https://example.org/id/location/myGlassFactory> ;
        ssn:hasSubSystem  <https://example.org/id/filter/waterFilter1> .

<https://example.org/id/withdrawalpoint/sandExtraction1>
        a                :WithdrawalPoint ;
        rdfs:label       "Sand Extraction Point A"@en ;
        dbo:depth        "2.5"^^xsd:decimal ;
        dc:created       "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        dc:issued        "2026-04-07"^^xsd:date ;
        dc:modified      "2026-04-07T07:05:35Z"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

# ============================================================
# FILTERS
# ============================================================

<https://example.org/id/filter/waterFilter1>
        a                ssn:System , :Filter ;
        rdfs:label       "Water Intake Filter 1"@en ;
        dc:created       "2025-05-10T06:00:00"^^xsd:dateTime ;
        dc:issued        "2025-05-01"^^xsd:date ;
        dc:modified      "2026-03-20T12:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/filter/dustFilter1>
        a                ssn:System , :Filter ;
        rdfs:label       "Furnace Dust Filter"@en ;
        dc:created       "2024-11-01T09:00:00"^^xsd:dateTime ;
        dc:issued        "2024-11-01"^^xsd:date ;
        dc:modified      "2026-01-15T10:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

# ============================================================
# MEASUREMENT POINTS
# ============================================================

<https://example.org/id/measurementpoint/stack1>
        a                 ssn:System , :MeasurementPoint ;
        rdfs:label        "Measurement Point Stack 1"@en ;
        dc:created        "2026-04-07T07:00:00"^^xsd:dateTime ;
        dc:issued         "2026-04-07"^^xsd:date ;
        dc:modified       "2026-04-07T07:00:00"^^xsd:dateTime ;
        adms:status       concept:active ;
        sosa:isHostedBy   <https://example.org/id/location/myGlassFactory> ;
        ssn:hasSubSystem  <https://example.org/id/measurementinstrument/gasAnalyzer> ;
        :section          <https://example.org/id/section/B1> .

<https://example.org/id/measurementpoint/water-discharge>
        a                 ssn:System , :MeasurementPoint ;
        rdfs:label        "Measurement Point Water Discharge"@en ;
        dc:created        "2026-04-07T07:05:00"^^xsd:dateTime ;
        dc:issued         "2026-04-07"^^xsd:date ;
        dc:modified       "2026-04-07T07:05:00"^^xsd:dateTime ;
        adms:status       concept:active ;
        sosa:isHostedBy   <https://example.org/id/location/myGlassFactory> ;
        ssn:hasSubSystem  <https://example.org/id/measurementinstrument/flowMeter> .

# ============================================================
# MEASUREMENT INSTRUMENTS
# ============================================================

<https://example.org/id/measurementinstrument/gasAnalyzer>
        a                ssn:System , :MeasurementInstrument ;
        rdfs:label       "Stack Gas Analyzer"@en ;
        dc:created       "2024-07-01T10:00:00"^^xsd:dateTime ;
        dc:issued        "2022-05-01"^^xsd:date ;
        dc:modified      "2024-07-01T10:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

<https://example.org/id/measurementinstrument/flowMeter>
        a                ssn:System , :MeasurementInstrument ;
        rdfs:label       "Effluent Flow Meter"@en ;
        dc:created       "2024-07-02T11:00:00"^^xsd:dateTime ;
        dc:issued        "2023-08-01"^^xsd:date ;
        dc:modified      "2024-07-02T11:00:00"^^xsd:dateTime ;
        adms:status      concept:active ;
        sosa:isHostedBy  <https://example.org/id/location/myGlassFactory> .

# ============================================================
# EMISSIONS
# ============================================================

<https://example.org/id/emission/co2-stack1>
        a           :Emission ;
        rdfs:label  "CO2 Emission Stack 1"@en .

<https://example.org/id/emission/nox-stack1>
        a           :Emission ;
        rdfs:label  "NOx Emission Stack 1"@en .

# ============================================================
# OBSERVATIONS AND RESULTS
# (Observations typed as :Observation only — not sosa:Observation —
#  to target only the custom :ObservationShape constraints.)
# ============================================================

<https://example.org/id/observation/co2-stack1-2026>
        a                          :Observation ;
        sosa:hasFeatureOfInterest  <https://example.org/id/emission/co2-stack1> ;
        sosa:hasResult             <https://example.org/id/observationresult/co2-stack1-2026> .

<https://example.org/id/observation/nox-stack1-2026>
        a                          :Observation ;
        sosa:hasFeatureOfInterest  <https://example.org/id/emission/nox-stack1> ;
        sosa:hasResult             <https://example.org/id/observationresult/nox-stack1-2026> .

<https://example.org/id/observationresult/co2-stack1-2026>
        a                  :ObservationResult , sosa:Result ;
        rdfs:label         "CO2 Measurement Result Stack 1 (2026)"@en ;
        qudt:numericValue  "12500.0"^^xsd:decimal ;
        qudt:hasUnit       unit:KiloGM-PER-HR .

<https://example.org/id/observationresult/nox-stack1-2026>
        a                  :ObservationResult , sosa:Result ;
        rdfs:label         "NOx Measurement Result Stack 1 (2026)"@en ;
        qudt:numericValue  "45.3"^^xsd:decimal ;
        qudt:hasUnit       unit:KiloGM-PER-HR .

# ============================================================
# MEASUREMENT PROCEDURES
# ============================================================

<https://example.org/id/measurementprocedure/continuousEmissionMonitoring>
        a           :MeasurementProcedure , sosa:Procedure ;
        rdfs:label  "Continuous Emission Monitoring (CEM)"@en ;
        dc:type     concept:continuousMonitoring .

<https://example.org/id/measurementprocedure/annualStackTest>
        a           :MeasurementProcedure , sosa:Procedure ;
        rdfs:label  "Annual Stack Test"@en ;
        dc:type     concept:periodicMeasurement .

# ============================================================
# EMISSION PROCEDURES
# ============================================================

<https://example.org/id/emissionprocedure/emissionFactor>
        a           :EmissionProcedure , sosa:Procedure ;
        rdfs:label  "Emission Factor Calculation Method"@en ;
        dc:type     concept:calculationMethod .

<https://example.org/id/emissionprocedure/directMeasurement>
        a           :EmissionProcedure , sosa:Procedure ;
        rdfs:label  "Direct Stack Emission Measurement"@en ;
        dc:type     concept:directMeasurement .

# ============================================================
# CONSUMPTION PROCEDURES
# ============================================================

<https://example.org/id/consumptionprocedure/massBalance>
        a           :ConsumptionProcedure , sosa:Procedure ;
        rdfs:label  "Mass Balance Method"@en ;
        dc:type     concept:calculationMethod .

<https://example.org/id/consumptionprocedure/fuelMetering>
        a           :ConsumptionProcedure , sosa:Procedure ;
        rdfs:label  "Fuel Flow Metering"@en ;
        dc:type     concept:directMeasurement .

# ============================================================
# TRANSPORT PROCEDURES
# ============================================================

<https://example.org/id/transportprocedure/conveyorTransport>
        a           :TransportProcedure , sosa:Procedure ;
        rdfs:label  "Conveyor Belt Transport of Raw Materials"@en ;
        dc:type     concept:mechanicalTransport .

<https://example.org/id/transportprocedure/pipelineTransport>
        a           :TransportProcedure , sosa:Procedure ;
        rdfs:label  "Pipeline Transport of Molten Glass"@en ;
        dc:type     concept:pipelineTransport .

# ============================================================
# PROCESSING PROCEDURES
# ============================================================

<https://example.org/id/processingprocedure/batchMixing>
        a           :ProcessingProcedure , sosa:Procedure ;
        rdfs:label  "Batch Mixing of Raw Materials"@en ;
        dc:type     concept:mixingProcess .

<https://example.org/id/processingprocedure/annealing>
        a           :ProcessingProcedure , sosa:Procedure ;
        rdfs:label  "Glass Annealing"@en ;
        dc:type     concept:thermalProcess .
