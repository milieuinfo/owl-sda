        dc:modified      "2024-06-20T14:30:00"^^xsd:dateTime ;
        adms:status      :actief ;
        sosa:isHostedBy  :OperationLocation-002 .

:EmissionPoint-001  rdf:type  :EmissionPoint ;
        rdfs:label       "Stack 1 Glass Factory"@en ;
        dbo:diameter     2.5 ;
        dbo:height       "30"^^xsd:decimal ;
        dc:created       "2024-01-15T10:00:00"^^xsd:dateTime ;
        dc:issued        "2024-01-01"^^xsd:date ;
        dc:modified      "2024-01-15T10:00:00"^^xsd:dateTime ;
        dc:type          concept:stack ;
        ogc:hasGeometry  [ rdf:type   ogc:Geometry ;
                           ogc:asWKT  "POINT(4.4026 51.2195)"^^ogc:wktLiteral
                         ] ;
        adms:status      :actief ;
        sosa:isHostedBy  :OperationLocation-001 .

:actief  rdf:type       adms:Status , skos:Concept ;
        rdfs:comment    "The active status indicates that an entity is currently in use."@en ;
        rdfs:label      "Active"@en ;
        skos:prefLabel  "Active"@en .

