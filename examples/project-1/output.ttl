@prefix :     <https://example.org/ns/riepr#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dc:   <http://purl.org/dc/terms/> .
@prefix geo:  <http://www.opengis.net/ont/geos#> .
@prefix m:    <https://example.org/ns/riepr#> .
@prefix ns:   <https://example.org/ns/riepr#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

m:OperationalStatus  rdf:type  adms:Status ;
        rdfs:label  "Operational" .

m:NewCompliantMeasurementPoint
        rdf:type    m:MeasurementPoint ;
        rdfs:label  "Minimal Compliant Point" ;
        dc:created  "2024-06-15T12:00:00Z"^^xsd:dateTime ;
        dc:issued   "2024-06-15"^^xsd:date .

m:activeStatus  rdf:type  adms:Status ;
        adms:value  "Active" .

m:Reading1  rdf:type     m:Measurement ;
        m:measuredValue  "23.1"^^xsd:float .

m:process1  rdf:type     m:Process ;
        rdfs:label       "Sample Process Instance" ;
        dc:created       "2023-01-01T00:00:00Z"^^xsd:dateTime ;
        dc:modified      "2023-01-01T00:00:00Z"^^xsd:dateTime ;
        adms:status      "PENDING" ;
        adms:status      adms:Status_PENDING ;
        m:adms:status    <m:Status_PENDING> ;
        m:hasIdentifier  "PROC-001" ;
        m:hasStatus      "PENDING" .

m:NewCompliantPoint  rdf:type  m:MeasurementPoint ;
        rdfs:label  "Compliant Test Point" ;
        dc:created  "2024-06-01T10:00:00Z"^^xsd:dateTime ;
        dc:issued   "2024-06-01"^^xsd:date .

m:NewMeasurementPoint
        rdf:type     m:MeasurementPoint ;
        rdfs:label   "Sample Measurement Point" ;
        dc:created   "2023-01-01T00:00:00Z"^^xsd:dateTime , "2023-01-01"^^xsd:date ;
        dc:modified  "2023-01-01T00:00:00Z"^^xsd:dateTime , "2023-01-01"^^xsd:date .

m:emPoint3  rdf:type     m:EmissionPoint ;
        rdfs:label       "Target City Emissions" ;
        dc:created       "2024-01-01" ;
        dc:issued        "2024-05-15" ;
        dc:modified      "2024-05-15" ;
        adms:status      m:activeStatus ;
        sosa:isHostedBy  m:hostEntity .

m:withdrawalPoint1  rdf:type  m:WithdrawalPoint ;
        skos:prefLabel  "Main Distribution Hub" ;
        adms:status     "Active" ;
        m:hasLocation   <http://example.org/locations/warehouseA> .

m:Installation1  rdf:type  m:Installation ;
        rdfs:label       "Primary Installation Site" ;
        dc:created       "2023-01-01T00:00:00Z"^^xsd:dateTime ;
        dc:issued        "2020-10-01"^^xsd:date ;
        dc:modified      "2023-10-27T10:00:00Z"^^xsd:dateTime ;
        adms:status      "Operational" ;
        adms:status      m:OperationalStatus ;
        sosa:isHostedBy  m:InfrastructureHub .

m:hostEntity  rdf:type  m:Host ;
        rdfs:label  "City Government" .

m:emPoint1  rdf:type       m:EmissionPoint ;
        m:hasEmissionRate  "100.5"^^xsd:double ;
        m:hasLocation      <http://example.org/locations/city_a> .

m:InfrastructureHub  rdf:type  m:OperationLocation ;
        rdfs:label  "Central Data Repository" .

m:Celsius  rdf:type  m:UnitOfMeasure ;
        m:name    "Celsius" .

m:SensorPoint1  rdf:type  m:MeasurementPoint ;
        m:hasMeasurement  m:Reading1 ;
        m:name            "RoomTemperatureSensor" ;
        m:unitOfMeasure   m:Celsius .
