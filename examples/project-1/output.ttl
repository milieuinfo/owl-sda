:OperationLocation-002
        rdf:type              :OperationLocation ;
        rdfs:label            "Chemical Plant Ghent Site"@en ;
        dc:created            "2024-02-01T09:00:00"^^xsd:dateTime ;
        dc:issued             "2024-02-01"^^xsd:date ;
        dc:modified           "2024-06-20T14:30:00"^^xsd:dateTime ;
        ogc:hasGeometry       [ rdf:type   ogc:Geometry ;
                                ogc:asWKT  "POINT(3.7174 51.0543)"^^ogc:wktLiteral
                              ] ;
        prov:wasAttributedTo  :Installation-002 .

:Installation-002  rdf:type  :Installation ;
        rdfs:label       "Chemical Processing Installation 1"@en ;
        dc:created       "2023-06-15T08:00:00"^^xsd:dateTime ;
