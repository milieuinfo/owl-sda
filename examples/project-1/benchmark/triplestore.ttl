:OperationLocation_2  rdf:type  :OperationLocation ;
        rdfs:label            "MyGlass factory Ghent"@en ;
        dc:created            "2020-11-01T00:00:00"^^xsd:dateTime ;
        dc:issued             "2020-11-01"^^xsd:date ;
        dc:modified           "2024-07-20T14:00:00"^^xsd:dateTime ;
        ogc:hasGeometry       [ rdf:type   ogc:Geometry ;
                                ogc:asWKT  "POINT(3.7259 51.0543)"^^ogc:wktLiteral
                              ] ;
        prov:wasAttributedTo  :Operator_2 .

:Address_Operator1  rdf:type  locn:Address ;
        rdfs:label          "Central Control Office, Amsterdam"@en ;
        locn:streetAddress  "Hoofdstraat 1"@en .

:EmissionPoint_2  rdf:type  :EmissionPoint ;
        rdfs:label       "Wastewater discharge point"@en ;
        dc:created       "2021-03-15T08:00:00"^^xsd:dateTime ;
        dc:issued        "2021-03-15"^^xsd:date ;
        dc:modified      "2024-07-20T14:00:00"^^xsd:dateTime ;
        adms:status      :actief ;
        sosa:isHostedBy  :OperationLocation_2 .

:Installation_2  rdf:type  :Installation ;
        rdfs:label       "Glass melting furnace MyGlass"@en ;
        dc:created       "2021-03-15T09:00:00"^^xsd:dateTime ;
