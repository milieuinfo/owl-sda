        dc:modified      "2024-07-20T14:00:00"^^xsd:dateTime ;
        adms:status      :actief ;
        sosa:isHostedBy  :OperationLocation_2 .

:Operator_2  rdf:type  :Operator ;
        rdfs:label    "Maintenance Supervisor"@en ;
        dc:type       :RoleType_Operator ;
        locn:address  :Address_Operator2 .

:actief  rdf:type       skos:Concept , adms:Status ;
        rdfs:comment    "The active status indicates that an entity is currently in use."@en ;
        rdfs:label      "Active"@en ;
        skos:prefLabel  "Active"@en .

:RoleType_Operator  rdf:type  dc:DCMIType ;
        rdfs:label  "Operator Role"@en .

:Address_Operator2  rdf:type  locn:Address ;
        rdfs:label          "Maintenance Workshop, Rotterdam"@en ;
        locn:streetAddress  "Industrieweg 42"@en .

