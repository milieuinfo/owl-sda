@prefix :           <http://www.w3.org/ns/org#> .
@prefix adms:       <http://www.w3.org/ns/adms#> .
@prefix cc:         <http://creativecommons.org/ns#> .
@prefix concept:    <https://example.org/id/concept/> .
@prefix dbo:        <http://dbpedia.org/ontology/> .
@prefix dc:         <http://purl.org/dc/elements/1.1/> .
@prefix dcat:       <http://www.w3.org/ns/dcat#> .
@prefix dct:        <http://purl.org/dc/terms/> .
@prefix dcterms:    <http://purl.org/dc/terms/> .
@prefix dtype:      <http://www.linkedmodel.org/schema/dtype#> .
@prefix foaf:       <http://xmlns.com/foaf/0.1/> .
@prefix geo:        <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix gr:         <http://purl.org/goodrelations/v1#> .
@prefix grddl:      <http://www.w3.org/2003/g/data-view#> .
@prefix gsp:        <http://www.opengis.net/ont/geosparql#> .
@prefix hydra:      <http://www.w3.org/ns/hydra/core#> .
@prefix locn:       <http://www.w3.org/ns/locn#> .
@prefix nace:       <http://data.europa.eu/ux2/nace2.1/> .
@prefix ogc:        <http://www.opengis.net/ont/geosparql#> .
@prefix org:        <http://www.w3.org/ns/org#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix owlTime:    <http://www.w3.org/2006/time#> .
@prefix pplan:      <http://purl.org/net/p-plan#> .
@prefix prov:       <http://www.w3.org/ns/prov#> .
@prefix qudt:       <http://qudt.org/schema/qudt/> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rec:        <http://www.w3.org/2001/02pd/rec54#> .
@prefix schema:     <http://schema.org/> .
@prefix sf:         <http://www.opengis.net/ont/sf#> .
@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix sioc:       <http://rdfs.org/sioc/ns#> .
@prefix skos:       <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa:       <http://www.w3.org/ns/sosa/> .
@prefix spec11:     <http://www.opengis.net/doc/IS/geosparql/1.1#> .
@prefix ssn:        <http://www.w3.org/ns/ssn/> .
@prefix ssn-system: <http://www.w3.org/ns/ssn/systems/> .
@prefix terms:      <http://purl.org/dc/terms/> .
@prefix time:       <http://www.w3.org/2006/time#> .
@prefix vaem:       <http://www.linkedmodel.org/schema/vaem#> .
@prefix vann:       <http://purl.org/vocab/vann/> .
@prefix vcard:      <http://www.w3.org/2006/vcard/ns#> .
