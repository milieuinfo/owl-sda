<https://example.org/ns/riepr#OperationLocationShape>
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operation location must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:created
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operation location must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:modified
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operation location can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:valid
                        ] ;
        sh:property     [ sh:description  "An operation location must have exactly 1 geometry"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         ogc:hasGeometry
                        ] ;
        sh:property     [ sh:class        adms:Identifier ;
                          sh:description  "An operation location has external identifiers (optional)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         adms:identifier
                        ] ;
        sh:property     [ sh:class     <https://example.org/ns/riepr#Operation> ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:deployedOnPlatform ]
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operation location must have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:issued
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#Operator> ;
                          sh:description  "An operation location must be linked to exactly one operator"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         prov:wasAttributedTo
                        ] ;
        sh:property     [ sh:description  "An operation location must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#OperationLocation> ;
                          sh:description  "An operation location can be a revision of another operation location (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        locn:Address ;
                          sh:description  "An operation location can have an address"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         locn:address
                        ] ;
        sh:property     [ sh:description  "An operation location can optionally be influenced by an org:Site or another type"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasInfluencedBy
                        ] ;
        sh:property     [ sh:class        org:Site ;
                          sh:description  "An operation location can match one location (VKBO)"@en ;
