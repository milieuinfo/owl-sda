@prefix wdrs:       <http://www.w3.org/2007/05/powder-s#> .
@prefix wdsr:       <http://www.w3.org/2007/05/powder-s#> .
@prefix wot:        <http://xmlns.com/wot/0.1/> .
@prefix xhv:        <http://www.w3.org/1999/xhtml/vocab#> .
@prefix xml:        <http://www.w3.org/XML/1998/namespace> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/ns/riepr#MeasurementPointShape>
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A system must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:modified
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can contain multiple objects."@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:hasSubSystem
                        ] ;
        sh:property     [ sh:class        adms:Identifier ;
                          sh:description  "A system has external identifiers (optional)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         adms:identifier
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#OperationLocation> ;
                          sh:description  "A system must be part of a location"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         [ sh:inversePath  sosa:hosts ]
                        ] ;
        sh:property     [ sh:description  "A system can have a type via dct:type"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:type
                        ] ;
        sh:property     [ sh:description  "A system can have at most 1 geometry"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ogc:hasGeometry
                        ] ;
        sh:property     [ sh:class     ssn:System ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:hasSubSystem ]
                        ] ;
        sh:property     [ sh:description  "A system must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A system must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:created
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A system must have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:issued
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#Section> ;
                          sh:description  "A measurement point can have multiple sections"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         <https://example.org/ns/riepr#section>
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#MeasurementInstrument> ;
                          sh:description  "A measurement point can have measuring instruments"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:hasSubSystem
                        ] ;
        sh:property     [ sh:class     <https://example.org/ns/riepr#Operation> ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:deployedSystem ]
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A system can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:valid
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can be a revision of other systems (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        adms:Status ;
                          sh:description  "A system must have a single status"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         adms:status
                        ] ;
        sh:targetClass  <https://example.org/ns/riepr#MeasurementPoint> .

rdfs:ClassShape  rdf:type  sh:NodeShape ;
        sh:targetClass  rdfs:Class .

prov:PersonShape  rdf:type  sh:NodeShape ;
        sh:targetClass  prov:Person .

qudt:SystemOfQuantityKindsShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:minCount  "0"^^xsd:int ;
                          sh:path      qudt:hasQuantityKind
                        ] ;
        sh:property     [ sh:class  qudt:QuantityKind ;
                          sh:path   qudt:hasQuantityKind
                        ] ;
        sh:property     [ sh:class  qudt:Enumeration ;
                          sh:path   qudt:baseDimensionEnumeration
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      qudt:baseDimensionEnumeration
                        ] ;
        sh:property     [ sh:class  qudt:QuantityKind ;
                          sh:path   qudt:systemDerivedQuantityKind
                        ] ;
        sh:property     [ sh:class  qudt:QuantityKind ;
                          sh:path   qudt:hasBaseQuantityKind
                        ] ;
        sh:property     [ sh:class  qudt:SystemOfUnits ;
                          sh:path   qudt:hasUnitSystem
                        ] ;
        sh:targetClass  qudt:SystemOfQuantityKinds .

qudt:DecimalPrefixShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:DecimalPrefix .

qudt:QuantityKindDimensionVector_CGSShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:QuantityKindDimensionVector_CGS .

qudt:DataEncodingShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      qudt:encoding
                        ] ;
        sh:property     [ sh:class  qudt:EndianType ;
                          sh:path   qudt:bitOrder
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      qudt:byteOrder
                        ] ;
        sh:property     [ sh:class  qudt:Encoding ;
                          sh:path   qudt:encoding
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      qudt:bitOrder
                        ] ;
        sh:targetClass  qudt:DataEncoding .

pplan:PlanShape  rdf:type  sh:NodeShape ;
        sh:targetClass  pplan:Plan .

ssn:OutputShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:class  sosa:Procedure ;
                          sh:path   [ sh:inversePath  ssn:hasOutput ]
                        ] ;
        sh:property     [ sh:minCount  "1"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:hasOutput ]
                        ] ;
        sh:targetClass  ssn:Output .

qudt:BinaryPrefixShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:BinaryPrefix .

prov:DerivationShape  rdf:type  sh:NodeShape ;
        sh:targetClass  prov:Derivation .

<https://example.org/ns/riepr#ProcessShape>
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:class     <https://example.org/ns/riepr#Installation> ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:implements ]
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A process must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:created
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#Process> ;
                          sh:description  "A process can be part of one or more other processes"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         pplan:isStepOfPlan
                        ] ;
        sh:property     [ sh:class        pplan:Variable ;
                          sh:description  "A process can have at least one input variable (substance)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         pplan:hasInputVar
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A process can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:valid
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A process can optionally use a variable that represents a system"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         [ sh:inversePath  ssn:implements ]
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A process can have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:issued
                        ] ;
        sh:property     [ sh:class        pplan:Variable ;
                          sh:description  "A process can have at least one output variable (substance)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         [ sh:inversePath  pplan:isOutputVarOf ]
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A process must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:modified
                        ] ;
        sh:property     [ sh:class        sosa:Procedure ;
                          sh:description  "A process can be derived from a (generic) procedure (optional). Max 1 because a process can only be derived from 1 procedure and this procedure would need to be a collection of other procedures."@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:type
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#Section> ;
                          sh:description  "A process can have multiple sections"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         <https://example.org/ns/riepr#section>
                        ] ;
        sh:property     [ sh:description  "A process must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#Process> ;
                          sh:description  "A process can be a revision of another process (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        adms:Status ;
                          sh:description  "A process must have a single status"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         adms:status
                        ] ;
        sh:targetClass  <https://example.org/ns/riepr#Process> .

qudt:RuleShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:minCount  "0"^^xsd:int ;
                          sh:path      qudt:rationale
                        ] ;
        sh:property     [ sh:class  qudt:RuleType ;
                          sh:path   qudt:ruleType
                        ] ;
        sh:targetClass  qudt:Rule .

qudt:EnumeratedValueShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:minCount  "0"^^xsd:int ;
                          sh:path      qudt:altSymbol
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      qudt:symbol
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      dct:description
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:path      qudt:abbreviation
                        ] ;
        sh:targetClass  qudt:EnumeratedValue .

voaf:VocabularyShape  rdf:type  sh:NodeShape ;
        sh:targetClass  voaf:Vocabulary .

sosa:ObservablePropertyShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:class  ssn:Stimulus ;
                          sh:path   [ sh:inversePath  ssn:isProxyFor ]
                        ] ;
        sh:property     [ sh:class  sosa:Observation ;
                          sh:path   [ sh:inversePath  sosa:observedProperty ]
                        ] ;
        sh:property     [ sh:class  sosa:Sensor ;
                          sh:path   [ sh:inversePath  sosa:observes ]
                        ] ;
        sh:targetClass  sosa:ObservableProperty .

qudt:BitEncodingTypeShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:BitEncodingType .

prov:CommunicationShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  prov:Communication .

<https://example.org/ns/riepr#ObservationResultShape>
        rdf:type        sh:NodeShape ;
        sh:targetClass  <https://example.org/ns/riepr#ObservationResult> .

foaf:ImageShape  rdf:type  sh:NodeShape ;
        sh:targetClass  foaf:Image .

org:OrganizationalCollaborationShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  org:OrganizationalCollaboration .

org:ChangeEventShape  rdf:type  sh:NodeShape ;
        sh:targetClass  org:ChangeEvent .

qudt:ByteEncodingTypeShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:ByteEncodingType .

qudt:TransformTypeShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:TransformType .

<https://example.org/ns/riepr#EmissionShape>
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:class     sosa:Observation ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  sosa:hasResult ]
                        ] ;
        sh:targetClass  <https://example.org/ns/riepr#Emission> .

qudt:CharEncodingTypeShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:CharEncodingType .

prov:BundleShape  rdf:type  sh:NodeShape ;
        sh:targetClass  prov:Bundle .

foaf:ProjectShape  rdf:type  sh:NodeShape ;
        sh:targetClass  foaf:Project .

pplan:BundleShape  rdf:type  sh:NodeShape ;
        sh:targetClass  pplan:Bundle .

qudt:PlaneAngleUnitShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:PlaneAngleUnit .

prov:AssociationShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  prov:Association .

qudt:QuantityTypeShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:class  qudt:QuantityKind ;
                          sh:path   dtype:value
                        ] ;
        sh:targetClass  qudt:QuantityType .

ogc:FeatureShape  rdf:type  sh:NodeShape ;
        sh:targetClass  ogc:Feature .

qudt:IntervalScaleShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:IntervalScale .

foaf:AgentShape  rdf:type  sh:NodeShape ;
        sh:targetClass  foaf:Agent .

org:PostShape  rdf:type  sh:NodeShape ;
        sh:targetClass  org:Post .

sosa:SamplingShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:minCount  "1"^^xsd:int ;
                          sh:path      [ sh:inversePath  sosa:isResultOf ]
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:minCount  "1"^^xsd:int ;
                          sh:path      [ sh:inversePath  sosa:isFeatureOfInterestOf ]
                        ] ;
        sh:property     [ sh:class  sosa:FeatureOfInterest ;
                          sh:path   [ sh:inversePath  sosa:isFeatureOfInterestOf ]
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:minCount  "1"^^xsd:int ;
                          sh:path      sosa:resultTime
                        ] ;
        sh:property     [ sh:class  sosa:Sampler ;
                          sh:path   [ sh:inversePath  sosa:madeSampling ]
                        ] ;
        sh:property     [ sh:maxCount  "1"^^xsd:int ;
                          sh:minCount  "1"^^xsd:int ;
                          sh:path      [ sh:inversePath  sosa:madeSampling ]
                        ] ;
        sh:property     [ sh:class  sosa:Procedure ;
                          sh:path   sosa:usedProcedure
                        ] ;
        sh:property     [ sh:class  sosa:Sample ;
                          sh:path   [ sh:inversePath  sosa:isResultOf ]
                        ] ;
        sh:targetClass  sosa:Sampling .

qudt:BooleanEncodingTypeShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:BooleanEncodingType .

<https://example.org/ns/riepr#OperatorContactPersonShape>
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:class     <https://example.org/ns/riepr#Operation> ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  org:hasMember ]
                        ] ;
        sh:property     [ sh:description  "An operator contact person must have a name"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         foaf:name
                        ] ;
        sh:property     [ sh:description  "An operator contact person can have an email address"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         foaf:mbox
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operator contact person can have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:modified
                        ] ;
        sh:property     [ sh:description  "An operator contact person must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operator contact person can have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:created
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operator contact person can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:valid
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operator contact person can have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:issued
                        ] ;
        sh:property     [ sh:description  "An operator contact person can have a phone number"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         foaf:phone
                        ] ;
        sh:property     [ sh:description  "An operator contact person can have a comment"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         rdfs:comment
                        ] ;
        sh:property     [ sh:description  "An operator contact person must have a role within the organization"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         org:hasRole
                        ] ;
        sh:targetClass  <https://example.org/ns/riepr#OperatorContactPerson> .

qudt:DerivedUnitShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  qudt:DerivedUnit .

ssn-system:SystemPropertyShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:class  ssn-system:SystemCapability ;
                          sh:path   [ sh:inversePath  ssn-system:hasSystemProperty ]
                        ] ;
        sh:property     [ sh:minCount  "1"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn-system:hasSystemProperty ]
                        ] ;
        sh:targetClass  ssn-system:SystemProperty .

<https://example.org/ns/riepr#InstallationShape>
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:description  "A system must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#Section> ;
                          sh:description  "An installation can have multiple sections"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         <https://example.org/ns/riepr#section>
                        ] ;
        sh:property     [ sh:description  "A system can have at most 1 geometry"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ogc:hasGeometry
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can be a revision of other systems (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        <https://example.org/ns/riepr#InstallationProperty> ;
                          sh:description  "An installation can have multiple installation properties"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         [ sh:inversePath  ssn:isPropertyOf ]
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A system can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:valid
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A system must have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:issued
                        ] ;
        sh:property     [ sh:description  "A system can have a type via dct:type"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dct:type
                        ] ;
        sh:property     [ sh:class        adms:Status ;
                          sh:description  "A system must have a single status"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         adms:status
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A system must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:created
                        ] ;
        sh:property     [ sh:class        adms:Identifier ;
                          sh:description  "A system has external identifiers (optional)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         adms:identifier
                        ] ;
        sh:property     [ sh:class     ssn:System ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:hasSubSystem ]
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can contain multiple objects."@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:hasSubSystem
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A system must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dct:modified
                        ] ;
        sh:property     [ sh:class     <https://example.org/ns/riepr#Operation> ;
                          sh:minCount  "0"^^xsd:int ;
