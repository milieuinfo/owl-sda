:ConsumptionProcedureShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  :ConsumptionProcedure .

:ProcessShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:class     :Installation ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      ssn:implementedBy
                        ] ;
        sh:property     [ sh:class        :Process ;
                          sh:description  "A process can be part of one or more other processes"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         pplan:isStepOfPlan
                        ] ;
        sh:property     [ sh:description  "A process must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:class        sosa:Procedure ;
                          sh:description  "A process can be derived from a (generic) procedure (optional). Max 1 because a process can only be derived from 1 procedure and this procedure would need to be a collection of other procedures."@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:type
                        ] ;
        sh:property     [ sh:class        :Process ;
                          sh:description  "A process can be a revision of another process (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A process can optionally use a variable that represents a system"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:implementedBy
                        ] ;
        sh:property     [ sh:class        :Section ;
                          sh:description  "A process can have multiple sections"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         :section
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A process can have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:issued
                        ] ;
        sh:property     [ sh:class        pplan:Variable ;
                          sh:description  "A process can have at least one input variable (substance)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         pplan:hasInputVar
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A process can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:valid
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A process must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:modified
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A process must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:created
                        ] ;
        sh:property     [ sh:class        adms:Status ;
                          sh:description  "A process must have a single status"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         adms:status
                        ] ;
        sh:property     [ sh:class        pplan:Variable ;
                          sh:description  "A process can have at least one output variable (substance)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         pplan:hasOutputVar
                        ] ;
        sh:targetClass  :Process .

:SectionShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:description  "A section can have a type via dct:type"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:type
                        ] ;
        sh:property     [ sh:description  "A section can have a description"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         skos:definition
                        ] ;
        sh:property     [ sh:description  "A section must have a code"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         skos:notation
                        ] ;
        sh:targetClass  :Section .

:ProcessingProcedureShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  :ProcessingProcedure .

:OperationShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:class        adms:Status ;
                          sh:description  "An operation has a status"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         adms:status
                        ] ;
        sh:property     [ sh:class        :Process ;
                          sh:description  "An operation implements a process"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         ssn:implements
                        ] ;
        sh:property     [ sh:class        :OperationLocation ;
                          sh:description  "An operation is performed at a specific operation location"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         ssn:deployedOnPlatform
                        ] ;
        sh:property     [ sh:class        adms:Identifier ;
                          sh:description  "An operation can have external identifiers (optional)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         adms:identifier
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operation must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:created
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operation must have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:issued
                        ] ;
        sh:property     [ sh:description  "An operation must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:class        :Contactpersoon ;
                          sh:description  "An operation can have multiple contact persons"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         org:hasMember
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operation can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:valid
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "An operation deploys systems"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:deployedSystem
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operation must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:modified
                        ] ;
        sh:targetClass  :Operation .

:InstallationShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:class        adms:Status ;
                          sh:description  "A system must have a single status"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         adms:status
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A system must have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:issued
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A system must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:modified
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "A system must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:created
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can be a revision of other systems (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        :Process ;
                          sh:description  "An installation can also contain processes that this installation implements"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:implements
                        ] ;
        sh:property     [ sh:class     :Operation ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      ssn:hasDeployment
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "A system can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:valid
                        ] ;
        sh:property     [ sh:description  "A system must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:class        :Section ;
                          sh:description  "An installation can have multiple sections"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         :section
                        ] ;
        sh:property     [ sh:class        adms:Identifier ;
                          sh:description  "A system has external identifiers (optional)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         adms:identifier
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can contain multiple objects."@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:hasSubSystem
                        ] ;
        sh:property     [ sh:class     ssn:System ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      [ sh:inversePath  ssn:hasSubSystem ]
                        ] ;
        sh:property     [ sh:description  "A system can have a type via dct:type"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:type
                        ] ;
        sh:property     [ sh:class        :OperationLocation ;
                          sh:description  "A system must be part of a location"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         sosa:isHostedBy
                        ] ;
        sh:property     [ sh:description  "A system can have at most 1 geometry"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ogc:hasGeometry
                        ] ;
        sh:property     [ sh:class        :InstallationProperty ;
                          sh:description  "An installation can have multiple installation properties"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ssn:hasProperty
                        ] ;
        sh:targetClass  :Installation .

:OperationLocationShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operation location can have a validity end"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dc:valid
                        ] ;
        sh:property     [ sh:class        adms:Identifier ;
                          sh:description  "An operation location has external identifiers (optional)"@en ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         adms:identifier
                        ] ;
        sh:property     [ sh:datatype     xsd:date ;
                          sh:description  "An operation location must have a validity start"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:issued
                        ] ;
        sh:property     [ sh:class     :Operation ;
                          sh:minCount  "0"^^xsd:int ;
                          sh:path      ssn:inDeployment
                        ] ;
        sh:property     [ sh:class        :Operator ;
                          sh:description  "An operation location must be linked to exactly one operator"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         prov:wasAttributedTo
                        ] ;
        sh:property     [ sh:description  "An operation location can optionally be influenced by an org:Site or another type"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasInfluencedBy
                        ] ;
        sh:property     [ sh:description  "An operation location must have a label"@en ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         rdfs:label
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operation location must have a modification date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:modified
                        ] ;
        sh:property     [ sh:class        locn:Address ;
                          sh:description  "An operation location can have an address"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         locn:address
                        ] ;
        sh:property     [ sh:datatype     xsd:dateTime ;
                          sh:description  "An operation location must have a creation date"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         dc:created
                        ] ;
        sh:property     [ sh:class        :OperationLocation ;
                          sh:description  "An operation location can be a revision of another operation location (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        org:Site ;
                          sh:description  "An operation location can match one location (VKBO)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:hadPrimarySource
                        ] ;
        sh:property     [ sh:description  "An operation location must have exactly 1 geometry"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         ogc:hasGeometry
                        ] ;
        sh:targetClass  :OperationLocation .

:WithdrawalPointShape
        rdf:type        sh:NodeShape ;
        sh:property     [ sh:description  "A withdrawal point can have a depth"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         dbo:depth
                        ] ;
        sh:property     [ sh:description  "A system can have at most 1 geometry"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         ogc:hasGeometry
                        ] ;
        sh:property     [ sh:class        ssn:System ;
                          sh:description  "A system can be a revision of other systems (optional)"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         prov:wasRevisionOf
                        ] ;
        sh:property     [ sh:class        ssn:System ;
