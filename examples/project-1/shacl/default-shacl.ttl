:EmissionProcedureShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  :EmissionProcedure .

:AbstractEmissionPointShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  :AbstractEmissionPoint .

:ObservationShape  rdf:type  sh:NodeShape ;
        sh:property     [ sh:class        sosa:Result ;
                          sh:description  "An observation must have a result."@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "0"^^xsd:int ;
                          sh:path         sosa:hasResult
                        ] ;
        sh:property     [ sh:class        :Emission ;
                          sh:description  "An observation must be linked to exactly one measurement point or installation"@en ;
                          sh:maxCount     "1"^^xsd:int ;
                          sh:minCount     "1"^^xsd:int ;
                          sh:path         sosa:hasFeatureOfInterest
                        ] ;
        sh:targetClass  :Observation .
