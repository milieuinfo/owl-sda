    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A measurement point is different from a withdrawal point (disjoint)"@en ;
        owl:disjointWith :WithdrawalPoint
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A measurement point can have multiple sections"@en ;
        owl:onProperty :section ;
        owl:someValuesFrom :Section ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A measurement point can have measuring instruments"@en ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom :MeasurementInstrument ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .
:MeasurementInstrument a owl:Class ;
    rdfs:label "Measurement Instrument"@en ;
    rdfs:comment "A measurement instrument is a specific device or system that is used to perform measurements at measurement points."@en ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system has external identifiers (optional)"@en ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can contain multiple objects."@en ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a label"@en ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a modification date"@en ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a creation date"@en ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a validity start"@en ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can have a validity end"@en ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must be part of a location"@en ;
        owl:onProperty sosa:isHostedBy ;
        owl:someValuesFrom :OperationLocation ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a single status"@en ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can be a revision of other systems (optional)"@en ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Operation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can have at most 1 geometry"@en ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can have a type via dct:type"@en ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .
:Filter a owl:Class ;
    rdfs:label "Filter"@en ;
    rdfs:comment "A filter is a specific system that is used to improve the quality of emissions by removing or reducing harmful substances."@en ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system has external identifiers (optional)"@en ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can contain multiple objects."@en ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a label"@en ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a modification date"@en ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a creation date"@en ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a validity start"@en ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can have a validity end"@en ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must be part of a location"@en ;
        owl:onProperty sosa:isHostedBy ;
        owl:someValuesFrom :OperationLocation ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system must have a single status"@en ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can be a revision of other systems (optional)"@en ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Operation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can have at most 1 geometry"@en ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A system can have a type via dct:type"@en ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .
:TransportProcedure a owl:Class, skos:Concept ;
    rdfs:label "Transport Procedure"@en ;
    rdfs:comment "A transport procedure is a specific procedure that relates to the transport of substances within or outside a process."@en ;
    rdfs:subClassOf sosa:Procedure .
:ProcessingProcedure a owl:Class, skos:Concept ;
    rdfs:label "Processing Procedure"@en ;
    rdfs:comment "A processing procedure is a specific procedure that relates to the processing of substances within a process."@en ;
    rdfs:subClassOf sosa:Procedure .
:ConsumptionProcedure a owl:Class, skos:Concept ;
    rdfs:label "Consumption Procedure"@en ;
    rdfs:comment "A consumption procedure is a specific procedure that relates to the transport of raw materials within a process."@en ;
    rdfs:subClassOf :TransportProcedure .
:EmissionProcedure a owl:Class, skos:Concept ;
    rdfs:label "Emission Procedure"@en ;
    rdfs:comment "An emission procedure is a specific procedure that relates to the release or discharge of substances at emission points."@en ;
    rdfs:subClassOf :TransportProcedure .
:MeasurementProcedure a owl:Class, skos:Concept ;
    rdfs:label "Measurement Procedure"@en ;
    rdfs:comment "A measurement procedure is a specific procedure that is used to perform measurements at measurement points."@en ;
    rdfs:subClassOf sosa:Procedure .
:Observation a owl:Class ;
    rdfs:label "Observation"@en ;
    rdfs:comment "An observation is a measurement or observation that was performed at a measurement point."@en ;
    rdfs:subClassOf sosa:Observation ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://example.org/id/observatie/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "An observation must be linked to exactly one measurement point or installation"@en ;
        owl:onProperty sosa:hasFeatureOfInterest ;
        owl:someValuesFrom :Emission ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "An observation must have a result."@en ;
        owl:onProperty sosa:hasResult ;
        owl:someValuesFrom sosa:Result ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .
:ObservationResult a owl:Class ;
    rdfs:label "Observation Result"@en ;
    rdfs:comment "An observation result is a specific result obtained from an observation."@en ;
    rdfs:subClassOf sosa:Result .
:Emission a owl:Class ;
    rdfs:label "Emission"@en ;
    rdfs:comment "An emission is a specific result that relates to the release or discharge of substances at emission points."@en ;
    rdfs:subClassOf sosa:Result ;
    owl:equivalentClass [ a owl:Restriction ;
        rdfs:comment "An emission must be linked to a process variable that is used within a process (as output) that is implemented by an emission point"@en ;
        owl:onProperty pplan:correspondsToVariable ;
        owl:someValuesFrom [ a owl:Restriction ;
            owl:onProperty pplan:isOutputVarOf ;
            owl:someValuesFrom [ a owl:Restriction ;
                owl:onProperty ssn:implementedBy ;
                owl:someValuesFrom :Emissionpunt
            ]
        ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        owl:onProperty sosa:isResultOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .
:Section a owl:Class ;
    rdfs:label "Section"@en ;
    rdfs:comment "A section is a specific classification that is used to categorize activities according to regulations."@en ;
    rdfs:subClassOf skos:Concept ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A section must have a code"@en ;
        owl:onProperty skos:notation ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A section can have a description"@en ;
        owl:onProperty skos:definition ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "A section can have a type via dct:type"@en ;
        owl:onProperty dct:type ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .
:section a owl:ObjectProperty ;
    rdfs:label "VLAREM Section"@en ;
    rdfs:comment "The VLAREM section that applies to a process or installation."@en ;
    rdfs:domain [ a owl:Class ;
        rdfs:comment "The VLAREM section can apply to processes"@en ;
        owl:unionOf ( :Installation )
    ] ;
    rdfs:range :Section .
:localId a rdfs:Datatype ;
    rdfs:label "Local Identifier"@en ;
    rdfs:comment "A local identifier is a unique identification within the context of RIE-IEPR."@en .
:putNummer a rdfs:Datatype ;
    rdfs:label "Groundwater Well Number"@en ;
    rdfs:comment "The well number of a groundwater well, used as identification within the context of RIE-IEPR."@en .
:serieNummer a rdfs:Datatype ;
    rdfs:label "Serial Number"@en ;
    rdfs:comment "The serial number of a system or component, used as identification within the context of RIE-IEPR."@en .
:actief a adms:Status, skos:Concept ;
    rdfs:label "Active"@en ;
    rdfs:comment "The active status indicates that an entity is currently in use."@en ;
    skos:prefLabel "Active"@en ;
    rdfs:equivalentClass <http://purl.org/adms/status/Completed> .
:inactief a adms:Status, skos:Concept ;
    rdfs:label "Inactive"@en ;
    rdfs:comment "The inactive status indicates that an entity is currently not in use."@en ;
    skos:prefLabel "Inactive"@en ;
    rdfs:equivalentClass <http://purl.org/adms/status/Deprecated> .
:gesloten a adms:Status, skos:Concept ;
    rdfs:label "Closed"@en ;
    rdfs:comment "The closed status indicates that an entity has been permanently taken out of service."@en ;
    skos:prefLabel "Closed"@en ;
    rdfs:equivalentClass <http://purl.org/adms/status/Withdrawn> .
:voorgesteld a adms:Status, skos:Concept ;
    rdfs:label "Proposed"@en ;
    rdfs:comment "The proposed status indicates that an entity has been proposed by the government but has not yet been confirmed."@en ;
    skos:prefLabel "Proposed"@en ;
    rdfs:equivalentClass <http://purl.org/adms/status/UnderDevelopment> .
:normaleToestand a ssn-system:Condition, skos:Concept ;
    rdfs:label "Normal Condition"@en ;
    rdfs:comment "The normal condition indicates that an installation operates within normal operational parameters."@en ;
    skos:prefLabel "Normal Condition"@en .
[ a owl:Class ;
    rdfs:comment "A process with an emission procedure must release or discharge substances at an emission point"@en ;
    owl:intersectionOf ( :Process [ a owl:Restriction ;
        owl:someValuesFrom :EmissionProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Emissionpunt
] .
[ a owl:Class ;
    rdfs:comment "A process with a ProcessingProcedure must process substances within an installation"@en ;
    owl:intersectionOf ( :Process [ a owl:Restriction ;
        owl:someValuesFrom :VerwerkingProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Installation
] .
[ a owl:Class ;
    rdfs:comment "A process with a measurement procedure must perform measurements at a measurement point"@en ;
    owl:intersectionOf ( :Process [ a owl:Restriction ;
        owl:someValuesFrom :MeetProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :MeasurementPoint
] .
pplan:isOutputVarOf owl:inverseOf pplan:hasOutputVar .