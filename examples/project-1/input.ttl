:InstallationProperty a owl:Class ;
    rdfs:label "Installation Property"@en ;
    rdfs:comment "An installation property is a specific property of an installation, such as capacity or efficiency."@en ;
    rdfs:subClassOf ssn-system:SystemProperty ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "An installation property must have a type"@en ;
        owl:onProperty dct:type ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "An installation property must have a value"@en ;
        owl:onProperty qudt:numericValue ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
